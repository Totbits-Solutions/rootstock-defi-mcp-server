# Rootstock MCP Server Configuration
# Copy to .env and adjust values

# --- Blockchain ---
MCP_RSK_NODE_URL=https://public-node.rsk.co

# --- Security ---
MCP_SECURITY__JWT_SECRET=change-me-to-a-strong-secret-at-least-32-chars
MCP_SECURITY__JWT_ALGORITHM=HS256
MCP_SECURITY__JWT_EXPIRATION_MINUTES=60

# --- Rate Limiting ---
MCP_RATE_LIMIT__REQUESTS_PER_MINUTE=60
MCP_RATE_LIMIT__BURST_SIZE=10

# --- Logging ---
MCP_LOG_LEVEL=INFO
MCP_LOG_FORMAT=pretty  # "pretty" for dev, "json" for production
